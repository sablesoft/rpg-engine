#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require "time"
require "pathname"
require_relative "support/workspace_card_headers"

ROOT = File.expand_path("..", __dir__)
PRODUCT_TMP = File.join(ROOT, "tmp")

def fail_with(message, code = 1)
  warn message
  exit code
end

def usage
  <<~TEXT
    Usage:
      ruby products/rpg-engine/scripts/image-save \
        --source products/rpg-engine/tmp/file.png \
        --owner-card PATH \
        --owner-type TYPE \
        --image-slug SLUG \
        --image-role ROLE \
        [options]

    Options:
      --owner-slug SLUG
      --provider-alias NAME
      --provider-driver NAME
      --prompt-summary TEXT
      --secondary-ref TYPE:SLUG:ROLE[:CARD_PATH]
      --render-status STATUS
      --notes TEXT
  TEXT
end

def parse_args(argv)
  options = {
    secondary_refs: [],
    render_status: "saved",
    provider_alias: "unknown",
    provider_driver: "unknown",
    prompt_summary: "",
    notes: ""
  }

  until argv.empty?
    flag = argv.shift
    case flag
    when "--source" then options[:source] = argv.shift
    when "--owner-card" then options[:owner_card] = argv.shift
    when "--owner-type" then options[:owner_type] = argv.shift
    when "--owner-slug" then options[:owner_slug] = argv.shift
    when "--image-slug" then options[:image_slug] = argv.shift
    when "--image-role" then options[:image_role] = argv.shift
    when "--provider-alias" then options[:provider_alias] = argv.shift
    when "--provider-driver" then options[:provider_driver] = argv.shift
    when "--prompt-summary" then options[:prompt_summary] = argv.shift
    when "--secondary-ref" then options[:secondary_refs] << argv.shift
    when "--render-status" then options[:render_status] = argv.shift
    when "--notes" then options[:notes] = argv.shift
    when "-h", "--help" then puts usage; exit 0
    else
      fail_with("Unknown option: #{flag}\n\n#{usage}", 64)
    end
  end

  %i[source owner_card owner_type image_slug image_role].each do |key|
    value = options[key]
    fail_with("Missing required option --#{key.to_s.tr('_', '-')}\n\n#{usage}", 64) if value.nil? || value.empty?
  end

  options
end

def relative_to_root(path)
  path.start_with?(ROOT) ? path.delete_prefix("#{ROOT}/") : path
end

def ensure_product_tmp!(source)
  abs = File.expand_path(source)
  tmp_prefix = "#{PRODUCT_TMP}/"
  fail_with("Source image must be inside #{PRODUCT_TMP}", 65) unless abs.start_with?(tmp_prefix) || abs == PRODUCT_TMP
  fail_with("Source image not found: #{abs}", 66) unless File.exist?(abs)
  abs
end

def infer_owner_slug(owner_card, owner_type, explicit_owner_slug)
  return explicit_owner_slug if explicit_owner_slug && !explicit_owner_slug.empty?

  basename = File.basename(owner_card, File.extname(owner_card))
  return basename unless %w[world scenario adventure current_scene].include?(basename)

  case owner_type
  when "world", "adventure", "scenario"
    File.basename(File.dirname(owner_card))
  when "scene"
    basename.tr("_", "-")
  else
    basename
  end
end

def detect_scope(owner_card)
  normalized = owner_card
  if normalized.include?("/workspaces/adventure/")
    match = normalized.match(%r{(.*/products/rpg-engine/workspaces/adventure/[^/]+)/})
    return [:adventure, match[1]]
  end

  if normalized.include?("/workspaces/world/") && normalized.include?("/scenarios/")
    match = normalized.match(%r{(.*/products/rpg-engine/workspaces/world/[^/]+/scenarios/[^/]+)/})
    return [:scenario, match[1]]
  end

  if normalized.include?("/workspaces/world/")
    match = normalized.match(%r{(.*/products/rpg-engine/workspaces/world/[^/]+)/})
    return [:world, match[1]]
  end

  fail_with("Could not determine scope from owner card path: #{owner_card}", 65)
end

def image_extension(source_path)
  ext = File.extname(source_path)
  ext.empty? ? ".png" : ext
end

def destination_paths(owner_card:, owner_type:, owner_slug:, image_slug:)
  scope_level, scope_root = detect_scope(owner_card)
  image_dir = File.join(scope_root, "images", owner_type, owner_slug)
  ext = image_extension(owner_card)
  [scope_level, image_dir, File.join(image_dir, image_slug)]
end

def destination_media_path(source_path, owner_card:, owner_type:, owner_slug:, image_slug:)
  scope_level, image_dir, stem = destination_paths(owner_card: owner_card, owner_type: owner_type, owner_slug: owner_slug, image_slug: image_slug)
  ext = image_extension(source_path)
  [scope_level, image_dir, "#{stem}#{ext}", "#{stem}.md"]
end

def temporary_card_path_for(source_path)
  base = source_path.sub(/\.[^.]+\z/, "")
  "#{base}.md"
end

def load_text(path)
  File.exist?(path) ? File.read(path) : ""
end

def write_text(path, content)
  File.write(path, "#{content.rstrip}\n")
end

def read_lines(path)
  File.exist?(path) ? File.readlines(path, chomp: true) : []
end

def append_section(path, header, lines)
  content = load_text(path).rstrip
  block = ([header] + lines).join("\n")
  section_pattern = /#{Regexp.escape(header)}\n.*?(?=\n## |\z)/m

  if content.include?(header)
    existing = section_lines(path, header)
    merged = merge_bullets(existing, lines)
    replacement = ([header] + merged).join("\n")
    updated = content.sub(section_pattern, replacement)
    File.write(path, "#{updated.rstrip}\n")
  else
    separator = content.empty? ? "" : "\n\n"
    File.write(path, "#{content}#{separator}#{block}\n")
  end
end

def replace_or_append_section(path, header, lines)
  content = load_text(path).rstrip
  block = ([header] + lines).join("\n")
  section_pattern = /#{Regexp.escape(header)}\n.*?(?=\n## |\z)/m

  if content.include?(header)
    updated = content.sub(section_pattern, block)
    write_text(path, updated)
  else
    separator = content.empty? ? "" : "\n\n"
    write_text(path, "#{content}#{separator}#{block}")
  end
end

def delete_section(path, header)
  content = load_text(path)
  return unless content.include?(header)

  updated = content.sub(/\n?#{Regexp.escape(header)}\n.*?(?=\n## |\z)/m, "")
  write_text(path, updated)
end

def section_lines(path, header)
  lines = read_lines(path)
  start = lines.index(header)
  return [] unless start

  collected = []
  index = start + 1
  while index < lines.length
    line = lines[index]
    break if line.start_with?("## ")
    collected << line
    index += 1
  end
  collected
end

def section_lines_any(path, headers)
  headers.each do |header|
    lines = section_lines(path, header)
    return [header, lines] unless lines.empty?
  end

  [headers.first, []]
end

def parse_visual_concept_entries(metadata_path)
  lines = section_lines(metadata_path, "## Visual Concept Basis")
  return [] if lines.empty?

  entries = []
  current = nil

  lines.each do |line|
    stripped = line.strip
    next if stripped.empty?
    next if stripped.start_with?("- visual_concept_gaps:")
    next if stripped.start_with?("- {{") || stripped.include?("{{")

    if stripped.start_with?("- participating_entity_visual_concepts:")
      next
    elsif stripped.start_with?("- type: ")
      entries << current if current
      current = { type: stripped.sub("- type: ", "").strip }
    elsif stripped.start_with?("type: ")
      entries << current if current
      current = { type: stripped.sub("type: ", "").strip }
    elsif current && stripped.start_with?("slug: ")
      current[:slug] = stripped.sub("slug: ", "").strip
    elsif current && stripped.start_with?("relation_to_image: ")
      current[:relation] = stripped.sub("relation_to_image: ", "").strip
    elsif current && stripped.start_with?("concept_status: ")
      current[:status] = stripped.sub("concept_status: ", "").strip
    elsif current && stripped.start_with?("concept_basis: ")
      current[:basis] = stripped.sub("concept_basis: ", "").strip
    end
  end

  entries << current if current
  entries.select { |entry| entry[:type] && entry[:slug] && entry[:basis] && !entry[:basis].empty? }
end

def extract_model_from_metadata(metadata_path)
  section_lines(metadata_path, "## Provider").each do |line|
    stripped = line.strip
    return stripped.sub("- model: ", "").strip if stripped.start_with?("- model: ")
  end
  nil
end

def extract_size_from_metadata(metadata_path)
  section_lines(metadata_path, "## Render Details").each do |line|
    stripped = line.strip
    return stripped.sub("- size: ", "").strip if stripped.start_with?("- size: ")
  end
  nil
end

def extract_seed_from_metadata(metadata_path)
  section_lines(metadata_path, "## Render Details").each do |line|
    stripped = line.strip
    return stripped.sub("- seed: ", "").strip if stripped.start_with?("- seed: ")
  end
  nil
end

def merge_bullets(existing_lines, new_bullets)
  existing_bullets = existing_lines.select { |line| line.start_with?("- ") }
  merged = existing_bullets.dup
  new_bullets.each do |bullet|
    merged << bullet unless merged.include?(bullet)
  end
  merged
end

def relative_path(from_path, to_path)
  Pathname.new(to_path).relative_path_from(Pathname.new(File.dirname(from_path))).to_s
end

def normalize_image_line(line)
  normalized = line.sub(/; preview: \[!\[[^\]]*\]\([^)]+\)\]\([^)]+\)/, "")
  normalized = normalized.sub(/; preview\b/, "")
  normalized.rstrip
end

def extract_image_slug(line)
  match = line.match(/`([^`]+)`/)
  match && match[1]
end

def extract_preview_slug(line)
  return extract_image_slug(line) if line.include?("; preview: [![") || line.include?("; preview")

  nil
end

def extract_card_path_from_line(line)
  match = line.match(/card: `([^`]+)`/)
  match && match[1]
end

def preview_info_from_images_section(owner_card)
  _header, lines = section_lines_any(owner_card, WorkspaceCardHeaders.aliases(:images))
  lines.each do |line|
    preview_slug = extract_preview_slug(line)
    next unless preview_slug

    card_path = extract_card_path_from_line(line)
    return { slug: preview_slug, card_path: card_path, line: line }
  end

  nil
end

def preview_info_from_preview_section(owner_card)
  preview_section_lines(owner_card).each do |line|
    match = line.match(/\[!\[([^\]]+)\]\(([^)]+)\)\]\([^)]+\)/)
    next unless match

    return {
      slug: match[1],
      media_path: File.expand_path(match[2], File.dirname(owner_card))
    }
  end

  nil
end

def resolve_preview_media_path(preview_info)
  return nil unless preview_info
  return nil unless preview_info[:card_path]

  metadata_path = File.join(ROOT, preview_info[:card_path])
  return nil unless File.exist?(metadata_path)

  section_lines(metadata_path, "## Files").each do |line|
    stripped = line.strip
    next unless stripped.start_with?("- media_file: ")

    rel_media = stripped.sub("- media_file: ", "").strip
    return File.join(ROOT, rel_media)
  end

  nil
end

def preview_section_lines(owner_card)
  _header, lines = section_lines_any(owner_card, WorkspaceCardHeaders.aliases(:preview))
  lines
end

def insert_preview_section(path, lines)
  content_lines = read_lines(path)
  block_lines = [WorkspaceCardHeaders.header(:preview), *lines]
  first_h2_index = content_lines.index { |line| line.start_with?("## ") }

  if first_h2_index
    insert_at = first_h2_index + 1
    while insert_at < content_lines.length && !content_lines[insert_at].start_with?("## ")
      insert_at += 1
    end

    updated_lines = content_lines.dup
    updated_lines.insert(insert_at, "", *block_lines)
    write_text(path, updated_lines.join("\n"))
    return
  end

  content = load_text(path).rstrip
  if content.start_with?("# ")
    first_newline = content.index("\n")
    if first_newline
      updated = "#{content[0..first_newline].rstrip}\n\n#{block_lines.join("\n")}\n\n#{content[(first_newline + 1)..].to_s.lstrip}"
      write_text(path, updated)
      return
    end
  end

  separator = content.empty? ? "" : "\n\n"
  write_text(path, "#{content}#{separator}#{block_lines.join("\n")}")
end

def remove_existing_preview_section(owner_card)
  header, lines = section_lines_any(owner_card, WorkspaceCardHeaders.aliases(:preview))
  return if lines.empty?

  delete_section(owner_card, header)
end

def ensure_preview_section(owner_card, preview_slug, media_path)
  return if preview_slug.nil? || preview_slug.empty?

  rel_media = relative_path(owner_card, media_path)
  remove_existing_preview_section(owner_card)
  insert_preview_section(owner_card, ["[![#{preview_slug}](#{rel_media})](#{rel_media})"])
end

def normalize_images_section(owner_card, preview_slug)
  header, existing_lines = section_lines_any(owner_card, WorkspaceCardHeaders.aliases(:images))
  return if existing_lines.empty?

  normalized = existing_lines
    .select { |line| line.start_with?("- ") }
    .map { |line| normalize_image_line(line) }
    .reject do |line|
      slug = extract_image_slug(line)
      slug == preview_slug
    end

  if normalized.empty?
    delete_section(owner_card, header)
  else
    replace_or_append_section(owner_card, WorkspaceCardHeaders.header(:images), normalized)
  end
end

def upsert_visual_concept(path, concept_basis)
  return if concept_basis.nil? || concept_basis.strip.empty?

  bullet = "- #{concept_basis.strip}"
  visual_header, existing = section_lines_any(path, WorkspaceCardHeaders.aliases(:visual_concept))

  if existing.empty?
    append_section(path, WorkspaceCardHeaders.header(:visual_concept), [bullet])
    return
  end

  merged = merge_bullets(existing, [bullet])
  content = load_text(path).rstrip
  updated = content.sub(/#{Regexp.escape(visual_header)}\n(?:.*\n)*?(?=## |\z)/m) do |_match|
    [WorkspaceCardHeaders.header(:visual_concept), *merged, ""].join("\n")
  end
  File.write(path, "#{updated.rstrip}\n")
end

def write_metadata(path:, image_slug:, owner_type:, owner_slug:, owner_card:, scope_level:, image_role:, provider_alias:, provider_driver:, prompt_summary:, render_status:, media_file:, secondary_refs:, notes:, visual_concept_entries:, model:, size:, seed:)
  lines = []
  lines << "# Image Card"
  lines << ""
  lines << "## Image Slug"
  lines << image_slug
  lines << ""
  lines << "## Owner"
  lines << "- entity_type: #{owner_type}"
  lines << "- entity_slug: #{owner_slug}"
  lines << "- owner_card_path: #{relative_to_root(owner_card)}"
  lines << "- scope_level: #{scope_level}"
  lines << ""
  lines << "## Secondary Entities"
  if secondary_refs.empty?
    lines << "- entity_refs: []"
  else
    lines << "- entity_refs:"
    secondary_refs.each do |ref|
      lines << "  - type: #{ref[:type]}"
      lines << "    slug: #{ref[:slug]}"
      lines << "    role_in_image: #{ref[:role]}"
    end
  end
  lines << ""
  lines << "## Visual Concept Basis"
  if visual_concept_entries.empty?
    lines << "- participating_entity_visual_concepts: []"
  else
    lines << "- participating_entity_visual_concepts:"
    visual_concept_entries.each do |entry|
      lines << "  - type: #{entry[:type]}"
      lines << "    slug: #{entry[:slug]}"
      lines << "    relation_to_image: #{entry[:relation] || 'participant'}"
      lines << "    concept_status: #{entry[:status] || 'existing-or-unspecified'}"
      lines << "    concept_basis: #{entry[:basis]}"
    end
  end
  lines << "- visual_concept_gaps: []"
  lines << ""
  lines << "## Role"
  lines << "- image_role: #{image_role}"
  lines << "- intended_use: saved-image"
  lines << ""
  lines << "## Provider"
  lines << "- provider_alias: #{provider_alias}"
  lines << "- provider_driver: #{provider_driver}"
  lines << "- model: #{model}" if model && !model.empty?
  lines << ""
  lines << "## Prompt Summary"
  lines << (prompt_summary.nil? || prompt_summary.empty? ? "Not recorded." : prompt_summary)
  lines << ""
  lines << "## Render Details"
  lines << "- render_status: #{render_status}"
  lines << "- size: #{size}" if size && !size.empty?
  lines << "- seed: #{seed}" if seed && !seed.empty?
  lines << "- created_at: #{Time.now.utc.iso8601}"
  lines << ""
  lines << "## Files"
  lines << "- media_file: #{media_file}"
  lines << ""
  lines << "## Notes"
  lines << (notes.nil? || notes.empty? ? "None." : notes)

  File.write(path, "#{lines.join("\n")}\n")
end

def parse_secondary_refs(raw_refs)
  raw_refs.map do |raw|
    parts = raw.split(":", 4)
    fail_with("Invalid --secondary-ref format: #{raw}", 64) if parts.length < 3
    {
      type: parts[0],
      slug: parts[1],
      role: parts[2],
      card_path: parts[3]
    }
  end
end

def update_owner_card(owner_card, image_role, metadata_path, media_path)
  rel_card = relative_to_root(metadata_path)
  image_slug = File.basename(metadata_path, ".md")
  existing_preview = preview_info_from_preview_section(owner_card) || preview_info_from_images_section(owner_card)
  preview_slug = existing_preview ? existing_preview[:slug] : image_slug
  preview_media_path = if existing_preview
    existing_preview[:media_path] || resolve_preview_media_path(existing_preview) || media_path
  else
    media_path
  end

  append_section(owner_card, WorkspaceCardHeaders.header(:images), ["- `#{image_slug}` — role: #{image_role}; card: `#{rel_card}`"])
  normalize_images_section(owner_card, preview_slug)
  ensure_preview_section(owner_card, preview_slug, preview_media_path)
end

def update_secondary_cards(secondary_refs, metadata_path)
  secondary_refs.each do |ref|
    next if ref[:card_path].nil? || ref[:card_path].empty?
    next unless File.exist?(ref[:card_path])

    rel = relative_to_root(metadata_path)
    append_section(
      ref[:card_path],
      WorkspaceCardHeaders.header(:related_images),
      ["- `#{File.basename(metadata_path, ".md")}` — role: #{ref[:role]}; card: `#{rel}`"]
    )
  end
end

def enrich_visual_concepts(owner_type, owner_slug, owner_card, secondary_refs, visual_concept_entries)
  entry_map = {}
  visual_concept_entries.each do |entry|
    entry_map[[entry[:type], entry[:slug]]] = entry[:basis]
  end

  upsert_visual_concept(owner_card, entry_map[[owner_type, owner_slug]])

  secondary_refs.each do |ref|
    next if ref[:card_path].nil? || ref[:card_path].empty?
    next unless File.exist?(ref[:card_path])

    upsert_visual_concept(ref[:card_path], entry_map[[ref[:type], ref[:slug]]])
  end
end

options = parse_args(ARGV.dup)
source_path = ensure_product_tmp!(options[:source])
temporary_card_path = temporary_card_path_for(source_path)
fail_with("Temporary image card not found: #{temporary_card_path}", 66) unless File.exist?(temporary_card_path)
owner_card = File.expand_path(options[:owner_card])
fail_with("Owner card not found: #{owner_card}", 66) unless File.exist?(owner_card)

owner_slug = infer_owner_slug(owner_card, options[:owner_type], options[:owner_slug])
scope_level, image_dir, media_path, metadata_path = destination_media_path(
  source_path,
  owner_card: owner_card,
  owner_type: options[:owner_type],
  owner_slug: owner_slug,
  image_slug: options[:image_slug]
)

FileUtils.mkdir_p(image_dir)
FileUtils.mv(source_path, media_path)
FileUtils.mv(temporary_card_path, metadata_path)

secondary_refs = parse_secondary_refs(options[:secondary_refs])
visual_concept_entries = parse_visual_concept_entries(metadata_path)
model = extract_model_from_metadata(metadata_path)
size = extract_size_from_metadata(metadata_path)
seed = extract_seed_from_metadata(metadata_path)
write_metadata(
  path: metadata_path,
  image_slug: options[:image_slug],
  owner_type: options[:owner_type],
  owner_slug: owner_slug,
  owner_card: owner_card,
  scope_level: scope_level,
  image_role: options[:image_role],
  provider_alias: options[:provider_alias],
  provider_driver: options[:provider_driver],
  prompt_summary: options[:prompt_summary],
  render_status: options[:render_status],
  media_file: relative_to_root(media_path),
  secondary_refs: secondary_refs,
  notes: options[:notes],
  visual_concept_entries: visual_concept_entries,
  model: model,
  size: size,
  seed: seed
)

enrich_visual_concepts(options[:owner_type], owner_slug, owner_card, secondary_refs, visual_concept_entries)
update_owner_card(owner_card, options[:image_role], metadata_path, media_path)
update_secondary_cards(secondary_refs, metadata_path)

puts [
  "saved_image=#{relative_to_root(media_path)}",
  "metadata_card=#{relative_to_root(metadata_path)}",
  "owner_type=#{options[:owner_type]}",
  "owner_slug=#{owner_slug}",
  "scope_level=#{scope_level}"
].join("\n")
